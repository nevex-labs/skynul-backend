# =============================================================================
# Skynul Backend - Environment Variables
# Copy this file to .env and fill in your values
# =============================================================================

# =============================================================================
# Server Configuration
# =============================================================================

# Port for the HTTP server (default: 3141)
PORT=3141

# Node environment (development | production)
NODE_ENV=production

# Enable/disable streaming responses
SKYNUL_STREAMING=true

# Data directory for persistence (SQLite, logs, etc.)
SKYNUL_DATA_DIR=./data

# Log level: debug | info | warn | error
SKYNUL_LOG_LEVEL=info

# =============================================================================
# Security
# =============================================================================

# JWT secret for authentication (generate a strong random string)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# API key for internal services
API_KEY=your-api-key-here

# =============================================================================
# AI Provider API Keys
# Add keys for the providers you want to use
# =============================================================================

# OpenAI (GPT-4, GPT-3.5)
OPENAI_API_KEY=sk-your-openai-key

# Anthropic (Claude)
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key

# Google (Gemini)
GEMINI_API_KEY=your-gemini-key

# DeepSeek
DEEPSEEK_API_KEY=your-deepseek-key

# Kimi (Moonshot)
KIMI_API_KEY=your-kimi-key

# OpenRouter (aggregates multiple providers)
OPENROUTER_API_KEY=sk-or-your-openrouter-key

# Ollama (local models)
OLLAMA_HOST=http://localhost:11434

# =============================================================================
# Blockchain (Optional - for trading features)
# =============================================================================

# Coinbase SDK API key
COINBASE_API_KEY=your-coinbase-key

# Wallet private key (for deployments)
CHAIN_WALLET_PRIVATE_KEY=your-private-key

# =============================================================================
# External Services (Optional)
# =============================================================================

# Supabase (for auth and persistence)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key

# Redis (for caching and task queue)
REDIS_URL=redis://localhost:6379

# Slack (for notifications)
SLACK_BOT_TOKEN=xoxb-your-token
SLACK_SIGNING_SECRET=your-signing-secret

# Discord (for bot)
DISCORD_BOT_TOKEN=your-discord-token

# Telegram (for bot)
TELEGRAM_BOT_TOKEN=your-telegram-token

# WhatsApp (for bot)
WHATSAPP_SESSION=your-session-id

# Polymarket (for prediction markets)
POLYMARKET_API_KEY=your-polymarket-key

# =============================================================================
# Development Only
# =============================================================================

# Enable debug mode (development only)
DEBUG=false

# Browser headless mode (false to see browser)
HEADLESS=true

# Paper trading mode (true = no real trades)
PAPER_TRADING=true
