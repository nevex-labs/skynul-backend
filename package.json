{
  "name": "@skynul/backend",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsup",
    "start": "node dist/index.js",
    "start:dev": "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "rebuild:sqlite": "cd ./node_modules/better-sqlite3 && node-gyp rebuild",
    "test": "vitest",
    "test:run": "vitest run"
  },
  "dependencies": {
    "@hono/node-server": "^1.14.1",
    "@hono/node-ws": "^1.3.0",
    "@hono/zod-validator": "^0.5.0",
    "@polymarket/clob-client": "^5.8.0",
    "@slack/bolt": "^4.6.0",
    "better-sqlite3": "^12.6.2",
    "discord.js": "^14.25.1",
    "ethers": "^6.16.0",
    "exceljs": "^4.4.0",
    "grammy": "^1.40.1",
    "hono": "^4.7.10",
    "playwright-core": "^1.58.2",
    "whatsapp-web.js": "^1.34.6",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@flydotio/dockerfile": "^0.7.10",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.5.0",
    "tsup": "^8.5.1",
    "tsx": "^4.19.4",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  },
  "engines": {
    "node": ">=22"
  }
}
