{
  "name": "@skynul/backend",
  "version": "0.0.1",
  "private": true,
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/nevex-labs/skynul-backend.git"
  },
  "homepage": "https://www.skynul.com",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "dev": "tsx watch --env-file=.env src/index.ts",
    "build": "tsup",
    "start": "node dist/index.js",
    "start:dev": "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "check": "pnpm lint && pnpm typecheck && pnpm test:run && pnpm build",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "test": "vitest",
    "test:run": "vitest run",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@coinbase/coinbase-sdk": "^0.25.0",
    "@hono/node-server": "^1.14.1",
    "@hono/node-ws": "^1.3.0",
    "@hono/zod-validator": "^0.5.0",
    "@polymarket/clob-client": "^5.8.0",
    "@slack/bolt": "^4.6.0",
    "discord.js": "^14.25.1",
    "dotenv": "^17.4.1",
    "drizzle-orm": "^0.45.2",
    "ethers": "^6.16.0",
    "exceljs": "^4.4.0",
    "grammy": "^1.40.1",
    "hono": "^4.7.10",
    "jose": "^6.2.2",
    "pg": "^8.20.0",
    "playwright-core": "^1.58.2",
    "viem": "^2.47.6",
    "whatsapp-web.js": "^1.34.6",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@flydotio/dockerfile": "^0.7.10",
    "@types/node": "^25.5.0",
    "@types/pg": "^8.20.0",
    "drizzle-kit": "^0.31.10",
    "tsup": "^8.5.1",
    "tsx": "^4.19.4",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  },
  "engines": {
    "node": ">=22"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@biomejs/biome",
      "esbuild",
      "puppeteer"
    ]
  }
}
