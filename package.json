{
  "name": "@skynul/backend",
  "version": "0.0.1",
  "private": true,
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/nevex-labs/skynul-backend.git"
  },
  "homepage": "https://www.skynul.com",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "dev": "tsx watch --env-file=.env src/index.ts",
    "dev:cli": "tsx src/cli/index.tsx",
    "build": "tsup",
    "start": "node dist/index.js",
    "start:dev": "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "rebuild:sqlite": "cd ./node_modules/better-sqlite3 && node-gyp rebuild",
    "test": "vitest",
    "test:run": "vitest run"
  },
  "dependencies": {
    "@coinbase/coinbase-sdk": "^0.25.0",
    "@effect/platform": "^0.96.0",
    "@effect/platform-node": "^0.106.0",
    "@hono/node-server": "^1.14.1",
    "@hono/node-ws": "^1.3.0",
    "@hono/zod-validator": "^0.5.0",
    "@polymarket/clob-client": "^5.8.0",
    "@slack/bolt": "^4.6.0",
    "better-sqlite3": "^12.6.2",
    "commander": "^14.0.3",
    "discord.js": "^14.25.1",
    "effect": "^3.21.0",
    "ethers": "^6.16.0",
    "exceljs": "^4.4.0",
    "grammy": "^1.40.1",
    "gray-matter": "^4.0.3",
    "hono": "^4.7.10",
    "ink": "^6.8.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "playwright-core": "^1.58.2",
    "react": "^19.2.4",
    "viem": "^2.47.6",
    "whatsapp-web.js": "^1.34.6",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@flydotio/dockerfile": "^0.7.10",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "tsup": "^8.5.1",
    "tsx": "^4.19.4",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  },
  "engines": {
    "node": ">=22"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["@biomejs/biome", "better-sqlite3", "esbuild", "puppeteer"]
  }
}
